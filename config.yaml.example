# Orchestratia Agent Daemon Configuration
# Copy to /etc/orchestratia/config.yaml and customize

hub_url: "https://staging.orchestratia.com"

# Authentication - use ONE of the following:
# 1. For first-time registration, get a token from the dashboard (Servers -> Register Server)
registration_token: "orcreg_xxx"
# 2. After registration, paste the API key here and remove registration_token
api_key: ""

server_name: "dev-linux-staging"

repos:
  my-backend-api:
    path: /home/ubuntu/my-backend-api
    branch: main
  my-frontend:
    path: /home/ubuntu/my-frontend
    branch: main

claude:
  binary: claude
  allowed_tools: "Bash,Read,Edit,Write,Grep,Glob"
  max_turns: 50
  timeout_minutes: 30

session:
  backend: screen
  log_dir: /var/log/orchestratia
  pid_dir: /var/run/orchestratia
  reconcile_on_start: true
